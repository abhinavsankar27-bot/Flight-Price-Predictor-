# Amadeus API Credentials (Test Environment)
AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# Database
DATABASE_URL=sqlite:///./data/flights.db

# Scheduled Job
# Comma-separated list of routes to track (Origin-Destination)
TRACKED_ROUTES=NYC-LON,SFO-JFK,BOS-MIA,LAX-HNL
TRACKING_CURRENCY=USD
